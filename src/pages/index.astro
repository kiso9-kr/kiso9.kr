---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function getThumbnail(post: (typeof posts)[number]) {
  if (post.data.type === 'youtube' && post.data.youtube) {
    return `https://img.youtube.com/vi/${post.data.youtube}/hqdefault.jpg`;
  }
  if (post.data.type === 'work' && post.data.image) {
    return post.data.image;
  }
  if (post.data.thumbnail) {
    return post.data.thumbnail;
  }
  return null;
}
---

<Layout>
  <ul>
    {posts.map((post) => {
      const thumb = getThumbnail(post);
      return (
        <li>
          <a href={`/posts/${post.slug}/`}>
            <div class="thumb">
              {thumb
                ? <img src={thumb} alt={post.data.title} loading="lazy" />
                : <div class="thumb-empty" />
              }
            </div>
            <p class="title">{post.data.title}</p>
          </a>
        </li>
      );
    })}
  </ul>
</Layout>

<style>
  ul {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem 1.25rem;
    margin-top: 2rem;
  }

  @media (max-width: 540px) {
    ul {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem 0.75rem;
    }
  }

  li a {
    display: block;
  }

  li a:hover .title {
    color: #555;
  }

  .thumb {
    width: 100%;
    background: #f0f0f0;
  }

  .thumb img {
    width: 100%;
    height: auto;
    display: block;
    transition: opacity 0.2s;
  }

  li a:hover .thumb img {
    opacity: 0.85;
  }

  .thumb-empty {
    width: 100%;
    height: 100%;
    background: #f0f0f0;
  }

  .title {
    margin-top: 0.5rem;
    font-size: 0.8rem;
    color: #999;
    line-height: 1.4;
    text-align: center;
  }
</style>
