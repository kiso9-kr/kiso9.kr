---
import Layout from '../layouts/Layout.astro';

const sections = [
  { name: 'Live Coding', href: '/live-coding', image: '/sections/Live Coding.jpg' },
  { name: 'Pod Cast',    href: '/posts/assastudy', image: '/sections/Pod Cast.jpg'    },
  { name: 'Play',        href: '/play',          image: '/sections/play.jpg'        },
  { name: 'etc',         href: '/etc',           image: '/sections/etc.jpg'         },
];
---

<Layout>
  <div class="page">
    <div class="sections-grid">
      {sections.map((section) => (
        <a href={section.href} class="section-card">
          <img src={section.image} alt={section.name} />
          <span class="section-name">{section.name}</span>
        </a>
      ))}
    </div>
  </div>
</Layout>

<style>
  .page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100%;
  }

  .sections-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
    width: 50%;
  }

  .section-card {
    position: relative;
    overflow: hidden;
    display: block;
    cursor: pointer;
    aspect-ratio: 1;
    text-decoration: none;
  }

  .section-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.35s ease;
  }

  .section-card:hover img {
    opacity: 0;
  }

  .section-name {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'MbahLiel', serif;
    font-size: 1.2rem;
    color: transparent;
    -webkit-text-stroke: 1px #111;
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
    text-decoration: none;
  }

  .section-card:hover .section-name {
    opacity: 1;
  }

  .section-card:hover {
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .sections-grid {
      width: 66.67%;
    }
  }
</style>
