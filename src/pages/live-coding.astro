---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const posts = (await getCollection('posts'))
  .filter((post) => post.data.section === 'live-coding')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function getThumbnail(post: (typeof posts)[number]) {
  if (post.data.type === 'youtube' && post.data.youtube) {
    return `https://img.youtube.com/vi/${post.data.youtube}/mqdefault.jpg`;
  }
  if (post.data.type === 'work' && post.data.image) {
    return post.data.image;
  }
  if (post.data.thumbnail) {
    return post.data.thumbnail;
  }
  return null;
}
---

<Layout title="Live Coding">
  <h2 class="section-title">Live Coding</h2>
  <ul>
    {posts.map((post) => {
      const thumb = getThumbnail(post);
      return (
        <li>
          <a href={`/posts/${post.slug}/`}>
            <div class="thumb">
              {thumb
                ? <img src={thumb} alt={post.data.title} loading="lazy" />
                : <div class="thumb-empty" />
              }
            </div>
            <p class="title">{post.data.title}</p>
          </a>
        </li>
      );
    })}
  </ul>
</Layout>

<style>
  .section-title {
    font-family: 'MbahLiel', serif;
    font-weight: normal;
    font-size: 2rem;
    margin-top: 2rem;
    margin-bottom: 1.5rem;
    color: transparent;
    -webkit-text-stroke: 1px #111;
  }

  ul {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    column-gap: 1.25rem;
    row-gap: 0;
  }

  @media (max-width: 540px) {
    ul {
      grid-template-columns: repeat(2, 1fr);
      column-gap: 0.75rem;
    }
  }

  li {
    display: grid;
    grid-template-rows: subgrid;
    grid-row: span 2;
  }

  li a {
    display: contents;
  }

  .thumb {
    width: 100%;
    background: #f0f0f0;
    position: relative;
    align-self: end;
  }

  .thumb img {
    width: 100%;
    height: auto;
    display: block;
    filter: grayscale(0);
    transition: filter 0.35s ease;
  }

  li a:hover .thumb img {
    filter: grayscale(1);
  }

  .thumb-empty {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: #f0f0f0;
  }

  .title {
    margin-top: 0.5rem;
    padding-bottom: 1.5rem;
    font-size: 0.8rem;
    color: #999;
    line-height: 1.4;
    text-align: center;
    text-decoration: none;
  }
</style>
